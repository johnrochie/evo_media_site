# Site URL for sitemap, robots, and Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.evomedia.site

# Optional: Calendly, Cal.com, or any booking URL — shows “Book a call” on the contact section
NEXT_PUBLIC_BOOKING_URL=

# Resend.com – contact form email delivery
# Get your API key at https://resend.com/api-keys
# Verify your domain at https://resend.com/domains for production
RESEND_API_KEY=re_QQH2tz5n_8ph3go1NG75vL4PtyVR6YYVQ
RESEND_TO=johnrochie86@gmail.com
# Use your verified domain after verifying at resend.com/domains
RESEND_FROM=Evolution Media <hello@evomedia.site>

# Crisp chat – website ID from app.crisp.chat → Setup → Website Settings
# Configure greeting, working hours (9 AM–6 PM GMT), and triggers in the dashboard
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Google Analytics 4 – measurement ID from analytics.google.com (e.g. G-XXXXXXXXXX)
# Only loads after user accepts analytics cookies
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console – add verification code from search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Supabase – intake forms storage (supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Notion – build brief syncing (notion.so, optional for Stage 2)
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# Stripe – payment processing (dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook secret from Stripe Dashboard → Developers → Webhooks
# For local testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry – error monitoring (sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
